            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"sts:AssumeRoleWithWebIdentity\",\n      \"Principal\": {\n        \"Federated\": \"arn:aws:iam::739961805636:oidc-provider/oidc.eks.ap-northeast-2.amazonaws.com/id/48D3D7EF88BFDFBE5659CC81405E4518\"\n      },\n      \"Condition\": {\n        \"StringEquals\": {\n          \"oidc.eks.ap-northeast-2.amazonaws.com/id/48D3D7EF88BFDFBE5659CC81405E4518:aud\": \"sts.amazonaws.com\",\n          \"oidc.eks.ap-northeast-2.amazonaws.com/id/48D3D7EF88BFDFBE5659CC81405E4518:sub\": \"system:serviceaccount:kube-system:ebs-csi-controller-sa\"\n        }\n      }\n    }\n  ]\n}",
            "minified_json": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Action\":\"sts:AssumeRoleWithWebIdentity\",\"Principal\":{\"Federated\":\"arn:aws:iam::739961805636:oidc-provider/oidc.eks.ap-northeast-2.amazonaws.com/id/48D3D7EF88BFDFBE5659CC81405E4518\"},\"Condition\":{\"StringEquals\":{\"oidc.eks.ap-northeast-2.amazonaws.com/id/48D3D7EF88BFDFBE5659CC81405E4518:aud\":\"sts.amazonaws.com\",\"oidc.eks.ap-northeast-2.amazonaws.com/id/48D3D7EF88BFDFBE5659CC81405E4518:sub\":\"system:serviceaccount:kube-system:ebs-csi-controller-sa\"}}}]}",
